{
    $schema: 'https://docs.renovatebot.com/renovate-schema.json',
    extends: [
        'config:recommended',
        'docker:pinDigests',
        'customManagers:dockerfileVersions',
    ],
    packageRules: [
        {
            matchFileNames: [
                'demo/**',
                'examples/**',
            ],
            enabled: false,
        },
        {
            matchFileNames: [
                'Dockerfile',
            ],
            schedule: [
                '* * 28-31 * *',
                '* 0-5 1 * *',
            ],
            automerge: true,
            groupName: 'base image',
        },
    ],
}
